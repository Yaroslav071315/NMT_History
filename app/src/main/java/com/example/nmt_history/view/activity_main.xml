<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/welcomeText"
        android:text="Вітаємо в додатку НМТ Історія"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/motivationText"
        android:text="Цитата"
        android:textSize="16sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnTests"
        android:text="📝 Тести"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:margin="8dp"/>

    <Button
        android:id="@+id/btnMaterials"
        android:text="📚 Матеріали"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:margin="8dp"/>

    <Button
        android:id="@+id/btnProgram"
        android:text="📖 Програма НМТ"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:margin="8dp"/>

    <Button
        android:id="@+id/btnProgress"
        android:text="📊 Прогрес"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:margin="8dp"/>

    <Button
        android:id="@+id/btnMonuments"
        android:text="🏛 Пам’ятки та персоналії"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:margin="8dp"/>
</LinearLayout>
